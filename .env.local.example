# Soul — Supabase configuration
#
# 1. Create a free project at https://supabase.com
# 2. In the dashboard, open the SQL Editor and run the contents of supabase/schema.sql
# 3. Go to Project Settings → API and copy the two values below
# 4. Copy this file to ".env.local" and fill them in
# 5. Restart the dev server (npm run dev)
#
# The anon (public) key is safe to expose in a client app — access is gated by
# Row Level Security. NEVER put the service_role key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional — 1:1 calls use WebRTC with a public STUN server by default. For calls
# between users on different / restrictive networks you also need a TURN relay.
# Without TURN, calls only connect on permissive or same networks.
#
# Quickest free option (great for testing) — Metered's public Open Relay. VITE_TURN_URL
# accepts a comma-separated list of transports; include TCP/TLS on 443 so calls connect
# even on networks that block UDP (otherwise a call can connect one direction but not the other):
#   VITE_TURN_URL=turn:openrelay.metered.ca:80,turn:openrelay.metered.ca:443?transport=tcp,turns:openrelay.metered.ca:443?transport=tcp
#   VITE_TURN_USERNAME=openrelayproject
#   VITE_TURN_CREDENTIAL=openrelayproject
# For production use your own relay (Metered / Twilio / Cloudflare free tiers, or
# self-hosted coturn). Leave blank to use STUN only.
# VITE_TURN_URL=turn:your-turn-host:3478
# VITE_TURN_USERNAME=YOUR-TURN-USERNAME
# VITE_TURN_CREDENTIAL=YOUR-TURN-CREDENTIAL

# Optional — GIPHY stickers in chat. Create a free beta API key at
# https://developers.giphy.com (Create an API Key → type "API", platform "Web").
# It's a client-side key (rate-limited ~100 calls/hr). Leave blank to hide the
# sticker button.
# VITE_GIPHY_API_KEY=YOUR-GIPHY-API-KEY
