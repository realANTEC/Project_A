# Soul — Supabase configuration
#
# 1. Create a free project at https://supabase.com
# 2. In the dashboard, open the SQL Editor and run the contents of supabase/schema.sql
# 3. Go to Project Settings → API and copy the two values below
# 4. Copy this file to ".env.local" and fill them in
# 5. Restart the dev server (npm run dev)
#
# The anon (public) key is safe to expose in a client app — access is gated by
# Row Level Security. NEVER put the service_role key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
